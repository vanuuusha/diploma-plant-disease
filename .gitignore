# ---------------------------------------------------------------------------
# Датасеты (суммарно ~1.8 GB, не влезают в git)
# Сохраняем только метаданные: data.yaml, README.md, summary.yaml
# ---------------------------------------------------------------------------
code/data/dataset/train/
code/data/dataset/val/
code/data/dataset/test/

code/data/dataset_augmented/train/
code/data/dataset_augmented/val/
code/data/dataset_augmented/test/

code/data/dataset_balanced/train/
code/data/dataset_balanced/val/
code/data/dataset_balanced/test/

code/data/dataset_final/train/
code/data/dataset_final/val/
code/data/dataset_final/test/

# Архивы данных
code/data/*.tar.gz
code/data/*.zip
code/data/*.tar

# ---------------------------------------------------------------------------
# Результаты (оставляем визуализации для диплома, но не детальные логи)
# ---------------------------------------------------------------------------
# Все .png / .csv / .yaml / .json / .md в results/ — КОММИТИМ (иллюстрации для диплома).
# Ничего не исключаем автоматически из code/results/ кроме технических логов ниже:
code/results/**/*.ipynb_checkpoints/
code/results/**/tmp_*
code/results/**/*.tmp

# ---------------------------------------------------------------------------
# Временные файлы
# ---------------------------------------------------------------------------
/tmp/
*.log
*.pid
.claude/scheduled_tasks.lock

# Результаты обучения (Ultralytics сохраняет в runs/ при train())
runs/
wandb/
mlruns/

# ---------------------------------------------------------------------------
# ВАЖНО: что НЕ игнорируется (явные keep-правила)
# ---------------------------------------------------------------------------
# dataset_final/ — пусть остаются README.md / data.yaml / summary.yaml
# и есть символьные ссылки на иллюстрации (ниже не нужно — по умолчанию коммитятся).

# Все 450 сгенерированных диффузией изображений в code/results/task_06/diffusion_v2/
# ОСТАВЛЯЮТСЯ В РЕПОЗИТОРИИ (≈212 МБ) — автор диплома сможет просмотреть и выбрать
# лучшие для включения в текст. Размер помещается в git (лимит GitHub — 1 ГБ на репо).

# NST, diffusion/ (первый прогон), nst_v2/, compare/ — тоже коммитятся, малые объёмы.
